# Cloudflare Pages Configuration
# This file configures how Cloudflare Pages builds and deploys your Next.js app

# Framework: Next.js 14+
# Build Command: cd webapp && npm install && npm run build
# Build Output Directory: webapp/.next
# Root Directory: /

# Environment variables (if needed)
# NODE_VERSION=20

# Custom redirects and routing
[[redirects]]
  from = "/canada-citizenship-test-practice/*"
  to = "/:splat"
  status = 200

# Headers for security and performance
[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options = "DENY"
    X-Content-Type-Options = "nosniff"
    X-XSS-Protection = "1; mode=block"
    Referrer-Policy = "strict-origin-when-cross-origin"

# Cache static assets
[[headers]]
  for = "/_next/static/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/static/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"
